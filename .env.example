DATABASE_URI=mongodb+srv://username:password@cluster.example.mongodb.net/findrooms
PAYLOAD_SECRET=replace-with-a-long-random-secret

# Supabase Storage qua S3-compatible API.
# Tạo bucket public tên room-images trong Supabase Storage, rồi tạo S3 access keys.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_S3_ENDPOINT=https://your-project-ref.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_BUCKET=room-images
SUPABASE_S3_ACCESS_KEY_ID=your-supabase-s3-access-key
SUPABASE_S3_SECRET_ACCESS_KEY=your-supabase-s3-secret-key
SUPABASE_S3_REGION=your-project-region
